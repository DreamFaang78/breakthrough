# Supabase project credentials (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Slug of the hospital to show on localhost / apex domains (no subdomain).
# Matches the seeded demo hospital.
NEXT_PUBLIC_DEFAULT_HOSPITAL_SLUG=sharma-hospital

# P2 — Email notifications via Resend (https://resend.com — free tier: 3k emails/mo)
# Leave blank to skip email; in-app bell still works without this.
RESEND_API_KEY=
NOTIFY_FROM_EMAIL=notifications@hospitalos.app

# Optional: guard the /api/notify internal endpoint
NOTIFY_SECRET=

# P3-A — Guard the /api/cron/* endpoints
CRON_SECRET=
