# Supabase project credentials (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Slug of the hospital to show on localhost / apex domains (no subdomain).
# Matches the seeded demo hospital.
NEXT_PUBLIC_DEFAULT_HOSPITAL_SLUG=sharma-hospital

# P2 — Email notifications via Resend (https://resend.com — free tier: 3k emails/mo)
# Leave blank to skip email; in-app bell still works without this.
RESEND_API_KEY=re_your_resend_api_key_here
NOTIFY_FROM_EMAIL=notifications@hospitalos.app

# Optional: guard the /api/notify internal endpoint
NOTIFY_SECRET=

# WhatsApp notifications to patients (confirmation, follow-up).
# Leave blank to skip WhatsApp; email + in-app bell still work without this.
# Meta Cloud API: WHATSAPP_API_URL=https://graph.facebook.com/v21.0/<PHONE_NUMBER_ID>/messages
# Indian BSPs (AiSensy/Interakt/Gupshup): set their send endpoint + adapt the body in lib/notify/whatsapp.ts
WHATSAPP_API_URL=
WHATSAPP_TOKEN=

# P3-A — Guard the /api/cron/* endpoints
CRON_SECRET=

# Cloudflare Turnstile — bot protection on the booking form (https://dash.cloudflare.com → Turnstile)
# Free forever. Get keys at: Cloudflare Dashboard → Turnstile → Add site
# Leave blank in dev to skip the widget (form still works without it).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
